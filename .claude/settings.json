{
    "permissions": {
        "allow": [
            "mcp__grep__*",
            "mcp__plugin_context7_context7__*"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR/scripts/claude-format-hook.sh\""
                    }
                ]
            }
        ]
    },
    "enabledPlugins": {
        "typescript-lsp@claude-plugins-official": true,
        "context7@claude-plugins-official": true
    },
    "enabledMcpjsonServers": ["grep"]
}
