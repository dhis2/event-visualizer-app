{
    "compilerOptions": {
        "strict": false,
        "target": "es2015",
        "lib": ["es2015", "dom"],
        "sourceMap": true,
        "allowJs": true,
        "esModuleInterop": true,
        "module": "es2015",
        "moduleResolution": "bundler",
        "types": ["cypress", "node"],
        "noEmit": true
    },
    "include": ["**/*.ts", "types"],
    "exclude": ["./support/component.ts"]
}
