{
    "name": "event-visualizer-app",
    "version": "0.0.1",
    "description": "Event visualizer app and plugin",
    "license": "BSD-3-Clause",
    "private": true,
    "scripts": {
        "build": "d2-app-scripts build",
        "start": "d2-app-scripts start",
        "test": "vitest run",
        "test:watch": "vitest",
        "deploy": "d2-app-scripts deploy",
        "lint": "./scripts/lint.sh",
        "format": "./scripts/format.sh",
        "generate-types": "./scripts/generate-types.sh",
        "cy:open": "start-server-and-test 'pnpm start' http://localhost:3000 'pnpm cypress open --e2e'",
        "cy:run": "start-server-and-test 'pnpm start' http://localhost:3000 'pnpm cypress run --browser chrome headless'",
        "cy:comp:open": "cypress open --component",
        "cy:comp:run": "cypress run --component --browser chrome headless",
        "sonar": "pnpm exec @sonar/scan -Dsonar.branch.name=$(git rev-parse --abbrev-ref HEAD)",
        "postinstall": "./scripts/postinstall.sh"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@cypress/vite-dev-server": "^7.3.3",
        "@dhis2/cli-app-scripts": "^12.11.0",
        "@dhis2/cli-style": "^10.7.10",
        "@dhis2/config-eslint": "^0.2.2",
        "@dhis2/config-prettier": "^0.2.2",
        "@dhis2/cypress-commands": "^10.1.2",
        "@eslint/compat": "^2.1.0",
        "@ls-lint/ls-lint": "^2.3.1",
        "@sonar/scan": "^4.3.6",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.9.1",
        "@types/prop-types": "^15",
        "@types/react": "^18.3.23",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "^6.0.2",
        "cypress": "^15.14.2",
        "cypress-real-events": "^1.15.0",
        "cypress-tags": "^1.2.2",
        "eslint": "^9.39.4",
        "eslint-plugin-testing-library": "^7.16.2",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.5",
        "openapi-typescript": "^7.13.0",
        "opensrc": "^0.7.2",
        "prettier": "^3.8.3",
        "resize-observer-polyfill": "^1.5.1",
        "start-server-and-test": "^3.0.4",
        "stylelint": "^17.12.0",
        "typescript": "^5",
        "typescript-language-server": "^5.3.0",
        "typescript-plugin-css-modules": "^5.2.0",
        "vite": "^8.0.14",
        "vitest": "^4.1.7",
        "vitest-canvas-mock": "^1.1.4"
    },
    "dependencies": {
        "@dhis2/analytics": "^29.5.1",
        "@dhis2/app-runtime": "^3.16.0",
        "@dhis2/app-service-data": "^3.16.0",
        "@dhis2/ui": "^10.15.1",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@reduxjs/toolkit": "^2.11.2",
        "@types/deep-equal": "^1.0.4",
        "classnames": "^2.5.1",
        "deep-equal": "^2.2.3",
        "deepmerge": "^4.3.1",
        "history": "^5.3.0",
        "moment": "^2.30.1",
        "prop-types": "^15.8.1",
        "query-string": "^9.3.1",
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "react-redux": "^9.2.0",
        "usehooks-ts": "^3.1.1"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": [
            "eslint",
            "prettier --check"
        ],
        "*.{css,scss,tsx}": [
            "stylelint --max-warnings=0"
        ],
        "*.{css,scss,json,md,MD,yml,YML,yaml,YAML}": [
            "prettier --check"
        ]
    },
    "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
